# REACT_APP_DATA_ENV env for loading data (dev | prod)
REACT_APP_DATA_ENV=prod

# REACT_APP_ENV env for working env, hiding logs, disabling on prod smth, etc... (dev | prod)
REACT_APP_ENV=dev

# 3rd patry api (REACT_APP_TZKT_API = https://api.ghostnet.tzkt.io | https://api.tzkt.io, REACT_APP_TZKT_LINK = https://ghostnet.tzkt.io | https://tzkt.io)
REACT_APP_TZKT_API=https://api.ghostnet.tzkt.io
REACT_APP_TZKT_LINK=https://ghostnet.tzkt.io
REACT_APP_TZKT_SERVICE_API=https://services.tzkt.io
REACT_APP_WERT_API=https://sandbox.wert.io

# indexer api
REACT_APP_GRAPHQL_API=https://api.mavenfinance.io/v1/graphql
REACT_APP_GRAPHQL_WSS_API=wss://api.mavenfinance.io/v1/graphql

# project metadata (REACT_APP_NETWORK = ghostnet | mainnet)
REACT_APP_NAME=MAVEN
REACT_APP_NETWORK=ghostnet

# cloudlfare env variables (IPFS_API_KEY & IPFS_PROJECT_ID both are encrypted and not set on local)
REACT_APP_IPFS_API_KEY=''
REACT_APP_IPFS_PROJECT_ID=''
NODE_VERSION='16.13.0'
