{
  "name": "mavryk-finance-dapp-frontend",
  "version": "1.0.0",
  "scripts": {
    "start": "PORT=3000 NODE_ENV=development REACT_APP_BACKEND_URL=http://localhost:8080 node scripts/start.js -r @cypress/instrument-cra start && open http://localhost:3000",
    "start:evenlop": "export NODE_OPTIONS=--openssl-legacy-provider && PORT=3000 NODE_ENV=development REACT_APP_BACKEND_URL=http://localhost:8080 node scripts/start.js -r @cypress/instrument-cra start && open http://localhost:3000",
    "build": "npm run graphql-compile && DISABLE_ESLINT_PLUGIN=true node scripts/build.js",
    "build:evenlop": "npm run graphql-compile && export NODE_OPTIONS=--openssl-legacy-provider && DISABLE_ESLINT_PLUGIN=true node scripts/build.js",
    "graphql-compile": "graphql-codegen --require dotenv/config --config ./codegen.ts dotenv_config_path=./.env.local; true",
    "graphql-compile-watch": "graphql-codegen --require dotenv/config --config ./codegen.ts dotenv_config_path=./.env.local",
    "import-contracts": "rm -Rf src/deployments && cp -R ../contracts/deployments src/deployments",
    "open-explorer": "open https://better-call.dev/hangzhou2net/KT1N4WXRdpxmqKVuukhQXX5kgc6JwJwyJrVH/",
    "analyze": "node scripts/build.js && source-map-explorer 'build/static/js/*.js'",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test": "node scripts/test.js",
    "cypress:test": "cypress run -s 'cypress/integration/**/*-spec.js'"
  },
