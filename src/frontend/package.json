{
  "name": "mavryk-finance-dapp-frontend",
  "version": "1.0.0",
  "scripts": {
    "start": "vite --config vite.user.config.mts",
    "start:user": "vite --config vite.user.config.mts",
    "start:gov": "vite --config vite.gov.config.mts",
    "build": "yarn graphql-compile && vite build --config vite.user.config.mts && mv build-user/index.user.html build-user/index.html",
    "build:user": "yarn graphql-compile && vite build --config vite.user.config.mts && mv build-user/index.user.html build-user/index.html",
    "build:gov": "yarn graphql-compile && vite build --config vite.gov.config.mts && mv build-gov/index.gov.html build-gov/index.html",
    "build:all": "yarn build:user && yarn build:gov",
    "preview": "vite preview",
    "graphql-compile": "graphql-codegen --require dotenv/config --config ./codegen.ts dotenv_config_path=./.env.local; true",
    "graphql-compile-watch": "graphql-codegen --require dotenv/config --config ./codegen.ts dotenv_config_path=./.env.local",
    "import-contracts": "rm -Rf src/deployments && cp -R ../contracts/deployments src/deployments",
    "analyze": "vite build && source-map-explorer 'build/assets/*.js'",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test": "node scripts/test.js",
    "cypress:test": "cypress run -s 'cypress/integration/**/*-spec.js'"
  },
  "dependencies": {
    "@floating-ui/react": "^0.26.1",
    "@mavrykdynamics/mavlet-dapp": "^1.0.2",
    "@mavrykdynamics/webmavryk": "^2.0.0",
    "@mavrykdynamics/webmavryk-http-utils": "^2.0.0",
    "@mavrykdynamics/webmavryk-mavlet-wallet": "^2.0.0",
    "@mavrykdynamics/webmavryk-michel-codec": "^2.0.0",
    "@mavrykdynamics/webmavryk-rpc": "^2.0.0",
    "@mavrykdynamics/webmavryk-utils": "^2.0.0",
    "@microsoft/signalr": "^7.0.7",
    "@tanstack/react-query": "^5.90.20",
    "@wert-io/widget-initializer": "^2.0.0",
    "bignumber.js": "^9.1.0",
    "buffer": "^6.0.3",
    "cipher-base": "^1.0.4",
    "classnames": "^2.3.2",
    "dayjs": "^1.11.5",
    "embla-carousel-react": "^6.2.0",
    "graphql": "16.5.0",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "ipfs-http-client": "^54.0.1",
    "is-ipfs": "^6.0.2",
    "lightweight-charts": "4.0.0",
    "lodash.debounce": "^4.0.8",
    "qs": "^6.11.0",
    "react": "^18.2.0",
    "react-avatar-editor": "^13.0.0",
    "react-collapsed": "^3.3.0",
    "react-cookie": "^4.1.1",
    "react-dom": "^18.2.0",
    "react-google-recaptcha-v3": "^1.9.5",
    "react-minimal-pie-chart": "8.3.0",
    "react-router": "^7.1.0",
    "react-select": "^5.7.7",
    "react-use": "^17.4.0",
    "styled-components": "6.1.8",
    "stylis": "^4.3.1",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@cypress/code-coverage": "^3.9.11",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/client-preset": "^4.1.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/qs": "6.9.15",
    "@types/react": "^18.2.79",
    "@types/react-avatar-editor": "^13.0.0",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.0.0",
    "babel-jest": "^27.4.2",
    "babel-plugin-styled-components": "^1.13.2",
    "cypress": "^8.4.1",
    "dotenv": "^10.0.0",
    "eslint": "^8.3.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-jsdoc": "^46.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.4.3",
    "jest-resolve": "^27.4.2",
    "jest-watch-typeahead": "^1.0.0",
    "prettier": "2.8.7",
    "prompts": "^2.4.2",
    "source-map-explorer": "^2.5.2",
    "typescript": "^5.1.6",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-tsconfig-paths": "^6.0.5",
    "web-vitals": "^2.1.0"
  },
  "resolutions": {
    "@types/qs": "6.9.15"
  },
  "jest": {
    "roots": [
      "<rootDir>/src"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.ts"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
      "<rootDir>/src/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(js|jsx|mjs|cjs|ts|tsx)$": "<rootDir>/config/jest/babelTransform.js",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|mjs|cjs|ts|tsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|mjs|cjs|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ],
    "modulePaths": [
      "<rootDir>/src"
    ],
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ],
    "resetMocks": true
  },
  "babel": {
    "presets": [
      "react-app"
    ]
  }
}
